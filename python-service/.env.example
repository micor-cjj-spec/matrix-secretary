
# Google Gemini via OpenAI-compatible API
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
OPENROUTER_MODEL=gemini-3.1-flash-lite
LLM_TRUST_ENV=true
APP_URL=http://127.0.0.1:10002
APP_TITLE=AI Secretary Demo
SKILL_CATALOG_URL=http://127.0.0.1:10002/api/skills

# Local Ollama example:
# OPENROUTER_API_KEY=ollama
# OPENROUTER_BASE_URL=http://127.0.0.1:11434/v1
# OPENROUTER_MODEL=qwen2.5:3b
# LLM_TRUST_ENV=false

# OpenRouter example:
# OPENROUTER_API_KEY=replace-with-your-openrouter-api-key
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=deepseek/deepseek-v4-flash:free
# LLM_TRUST_ENV=true